{
  "name": "outreachhub-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "worker": "tsx watch --env-file=.env src/worker.ts",
    "typeorm": "tsx node_modules/typeorm/cli.js",
    "db:migration:generate": "tsx node_modules/typeorm/cli.js migration:generate -d src/modules/shared/database/dataSource.ts",
    "db:migration:run": "tsx node_modules/typeorm/cli.js migration:run -d src/modules/shared/database/dataSource.ts",
    "db:seed": "tsx --env-file=.env src/modules/shared/database/seed.ts"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.80.0",
    "cheerio": "^1.2.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.22.2",
    "googleapis": "^173.0.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "nanoid": "^6.0.0",
    "node-cron": "^4.6.0",
    "nodemailer": "^9.0.3",
    "p-limit": "^7.3.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.31",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.8",
    "@types/node": "^20",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.1",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/pg": "^8.11.10",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.23.0",
    "typescript": "^5"
  }
}
